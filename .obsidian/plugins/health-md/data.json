  "mapTilesEnabled": true,
  "mapTileUrl": "https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png",
  "mapTileAttribution": "© OpenStreetMap contributors © CARTO"
