{
	"name": "obsidian-health-md",
	"version": "2.0.2",
	"description": "Obsidian plugin for Health.md visualizations",
	"repository": {
		"type": "git",
		"url": "https://github.com/CodyBontecou/health-md-visualizations.git"
	},
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"test": "node scripts/check-data-folder-layout.mjs && node --test tests/*.test.mjs",
		"generate:mock-health": "node scripts/generate-mock-health-data.mjs",
		"generate:mock-android": "node scripts/generate-mock-android-export.mjs",
		"prepare:submission": "npm run build && node scripts/prepare-obsidian-submission.mjs"
	},
	"keywords": [],
	"author": "Cody Bontecou",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"esbuild": "^0.24.0",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.2.4",
		"obsidian": "^1.13.0",
		"typescript": "^5.6.0"
	},
	"dependencies": {
		"@types/leaflet": "^1.9.21",
		"leaflet": "^1.9.4"
	}
}
